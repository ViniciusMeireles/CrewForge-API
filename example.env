# ─── Cookie / SameSite Configuration ──────────────────────────────────
# In production (HTTPS):  SameSite=None + Secure=True  (cross-origin)
# In local dev (HTTP):    SameSite=Lax  + Secure=False (cross-origin)
#
# WARNING: SameSite=None + Secure=False is INVALID and cookies will be
# silently rejected by modern browsers.
# SESSION_COOKIE_SAMESITE=None       # None (prod) | Lax (dev)
# CSRF_COOKIE_SAMESITE=None          # None (prod) | Lax (dev)
# SESSION_COOKIE_SECURE=True         # True (prod) | False (dev)
# CSRF_COOKIE_SECURE=True            # True (prod) | False (dev)

# Shared session cookie domain for subdomains (e.g. .example.com)
# SESSION_COOKIE_DOMAIN=.example.com

# Trusted origins for CSRF (required for cross-origin POST requests)
# CSRF_TRUSTED_ORIGINS=https://app.example.com

